# Vaultfire OpenAI Agents — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Private key for write operations (register agent, create bond)
# Required only for write tools (vaultfire_register_agent, vaultfire_create_bond)
PRIVATE_KEY=your_private_key_here

# OpenAI API key for the Agents SDK
OPENAI_API_KEY=your_openai_api_key_here

# Optional: custom RPC URLs (overrides defaults)
# BASE_RPC_URL=https://mainnet.base.org
# AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# ARBITRUM_RPC_URL=https://arbitrum-one.publicnode.com
# POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
